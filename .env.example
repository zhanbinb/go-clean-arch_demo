# =============================================================================
# go-clean-arch_demo — Environment variables template
# =============================================================================
#
# Copy this file to `.env` and fill in your local values:
#     cp .env.example .env
#
# All variables are prefixed with `APP_` and override config.yaml values.
# config.Load() applies env vars at the highest precedence (above YAML files).
#
# Sensitive values (passwords, secrets) should NEVER be committed;
# `.env` is gitignored.
# =============================================================================

# ----- Runtime mode ----------------------------------------------------------
# APP_ENV selects which YAML override to load (config.<env>.yaml).
# Valid: local | dev | ci | prod (any string works; falls back gracefully).
APP_ENV=local

# ----- Server ----------------------------------------------------------------
APP_SERVER_HTTP_PORT=9090
APP_SERVER_GRPC_PORT=9091
# debug | release | test
APP_SERVER_MODE=debug

# ----- Database (MySQL) ------------------------------------------------------
APP_DATABASE_HOST=127.0.0.1
APP_DATABASE_PORT=3306
APP_DATABASE_USER=app
APP_DATABASE_PASSWORD=change-me
APP_DATABASE_NAME=article
APP_DATABASE_MAX_OPEN_CONNS=50
APP_DATABASE_MAX_IDLE_CONNS=10
APP_DATABASE_CONN_MAX_LIFETIME=3600
# silent | error | warn | info
APP_DATABASE_LOG_LEVEL=warn

# ----- JWT -------------------------------------------------------------------
# IMPORTANT: must be at least 16 bytes. Use a random secret in production:
#   openssl rand -base64 48
APP_JWT_SECRET=change-me-in-production-min-32-bytes-long
# Access token TTL (Go duration: 1h, 30m, 24h, ...)
APP_JWT_TTL=1h
# Refresh token TTL
APP_JWT_REFRESH_TTL=24h

# ----- Logging ---------------------------------------------------------------
# debug | info | warn | error
APP_LOG_LEVEL=debug
# json (production) | console (development)
APP_LOG_FORMAT=console

# ----- CORS ------------------------------------------------------------------
# Comma-separated list. Use "*" only for development.
APP_CORS_ALLOW_ORIGINS=*
APP_CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
APP_CORS_ALLOW_HEADERS=Origin,Content-Type,Authorization,X-Request-ID
APP_CORS_EXPOSE_HEADERS=X-Request-ID
APP_CORS_ALLOW_CREDENTIALS=false
APP_CORS_MAX_AGE=43200

# ----- Rate limiting ---------------------------------------------------------
APP_RATELIMIT_ENABLED=true
APP_RATELIMIT_RPS=100
APP_RATELIMIT_BURST=200
APP_RATELIMIT_CLEANUP_INTERVAL=300
# ip | user
APP_RATELIMIT_DIMENSION=ip

# ----- Swagger ---------------------------------------------------------------
APP_SWAGGER_ENABLED=true
APP_SWAGGER_PATH=/swagger
